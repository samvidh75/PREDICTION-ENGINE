# NPM Configuration for Vercel builds

# Skip building optional dependencies (onnxruntime-node causes timeout)
# onnxruntime-node is not needed - we use onnxruntime-web in browser
optional=false

# Increase network timeout for CDN downloads
fetch-timeout=60000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-retries=10

# Registry
registry=https://registry.npmjs.org/
