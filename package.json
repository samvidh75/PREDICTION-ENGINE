{
  "name": "prediction-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:frontend",
    "redis:health": "npx tsx scripts/redis-health.ts",
    "build:frontend": "npm run typecheck:frontend && vite build",
    "build:vercel": "npm run typecheck:vercel && vite build",
    "build:backend": "npm run typecheck:backend && npm run compile:backend",
    "build:render": "npm run compile:backend",
    "build:docker": "npm run compile:backend && npm run build:frontend",
    "build:all": "npm run build && npm run build:backend",
    "compile:backend": "tsc -p tsconfig.backend.emit.json && node scripts/fix-esm-imports.js",
    "start": "node dist/backend/backend/startServer.js",
    "start:dev": "tsx src/backend/startServer.ts",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "npm run typecheck:all",
    "typecheck:frontend": "tsc -p tsconfig.frontend.json --noEmit",
    "typecheck:vercel": "tsc -p tsconfig.frontend.json --noEmit",
    "typecheck:backend": "tsc -p tsconfig.backend.json --noEmit",
    "typecheck:active": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:providers": "tsc -p tsconfig.providers.json --noEmit",
    "typecheck:ingestion": "tsc -p tsconfig.ingestion.json --noEmit",
    "typecheck:repo": "tsc -p tsconfig.all.json --noEmit",
    "typecheck:all": "npm run typecheck:active && npm run typecheck:providers && npm run typecheck:ingestion && npm run typecheck:repo",
    "typecheck:legacy": "tsc -p tsconfig.all.json --noEmit",
    "test": "vitest run",
    "test:unit": "node scripts/run-vitest-ci.mjs",
    "test:unit:ci": "node scripts/run-vitest-ci.mjs",
    "test:integration:sqlite": "cross-env NODE_ENV=test DB_ADAPTER=sqlite ALLOW_SQLITE_FALLBACK=true SQLITE_DB_PATH=tmp/integration-sqlite.db vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test tests/playwright/f3-product-regression.spec.ts",
    "test:e2e:uiux": "vitest run tests/e2e/uiux",
    "qa:screenshots": "npx tsx scripts/capture-ui-screenshots.ts",
    "test:integration:postgres": "cross-env NODE_ENV=test DB_ADAPTER=postgres ALLOW_SQLITE_FALLBACK=false COOKIE_SECRET=test-only-ci-secret vitest run --config vitest.integration.config.ts",
    "test:integration:postgres:ci": "cross-env REQUIRE_POSTGRES_INTEGRATION=true NODE_ENV=test DB_ADAPTER=postgres ALLOW_SQLITE_FALLBACK=false COOKIE_SECRET=test-only-ci-secret vitest run --config vitest.integration.config.ts",
    "seed:ci": "tsx scripts/seed-ci-fixtures.ts",
    "test:watch": "vitest",
    "test:coverage": "node scripts/run-vitest-ci.mjs --coverage",
