{
  "name": "prediction-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npx tsc -p tsconfig.json --noEmit && vite build",
    "build:vercel": "npm run typecheck:vercel && vite build",
    "build:backend": "tsc -p tsconfig.backend.json --noEmit",
    "build:all": "npm run build && npm run build:backend",
    "compile:backend": "tsc -p tsconfig.backend.emit.json",
    "start": "node dist/backend/backend/startServer.js",
    "start:dev": "tsx src/backend/startServer.ts",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "npm run typecheck:all",
    "typecheck:frontend": "tsc -p tsconfig.json --noEmit",
    "typecheck:vercel": "tsc -p tsconfig.frontend.json --noEmit",
    "typecheck:backend": "tsc -p tsconfig.backend.json --noEmit",
    "typecheck:all": "tsc -p tsconfig.all.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration:sqlite": "cross-env NODE_ENV=test DB_ADAPTER=sqlite ALLOW_SQLITE_FALLBACK=true SQLITE_DB_PATH=tmp/integration-sqlite.db vitest run --config vitest.integration.config.ts",
    "test:e2e:uiux": "vitest run tests/e2e/uiux",
    "test:integration:postgres": "cross-env NODE_ENV=test DB_ADAPTER=postgres ALLOW_SQLITE_FALLBACK=false COOKIE_SECRET=test-only-ci-secret vitest run --config vitest.integration.config.ts",
    "test:integration:postgres:ci": "cross-env REQUIRE_POSTGRES_INTEGRATION=true NODE_ENV=test DB_ADAPTER=postgres ALLOW_SQLITE_FALLBACK=false COOKIE_SECRET=test-only-ci-secret vitest run --config vitest.integration.config.ts",
    "seed:ci": "tsx scripts/seed-ci-fixtures.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "validate:schema": "tsx scripts/validate-schema-contract.ts",
    "validate:data-integrity": "tsx scripts/validate-data-integrity.ts",
    "validate:query-schema": "tsx scripts/audit-query-schema-compatibility.ts",
    "validate:import-case": "node scripts/audit-import-case.mjs",
    "validate:temp-cleanup": "node scripts/validate-temp-cleanup.mjs",
    "validate:portability": "npm run validate:import-case && npm run validate:temp-cleanup && npm run doctor:platform",
    "validate:distributions": "tsx scripts/validate-sector-distributions.ts",
    "smoke:api": "tsx scripts/smoke-test-api.ts",
    "validate:api-states": "tsx scripts/smoke-test-api.ts",
    "validate:hygiene": "tsx scripts/validate-repository-hygiene.ts",
    "release:gate": "tsx scripts/release-gate.ts",
    "test:providers": "tsx src/scripts/provider-live-test.ts",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/websocket": "^11.2.0",
    "@tanstack/react-query": "^5.101.0",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "firebase": "^11.3.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.25.1",
    "lru-cache": "^11.3.6",
    "lucide-react": "^0.300.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.22.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.2",
    "vitest": "^1.5.0"
  }
}
