{
  "name": "prediction-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npx tsc -p tsconfig.json --noEmit && vite build",
    "build:backend": "tsc -p tsconfig.backend.json --noEmit",
    "compile:backend": "vite build --config vite.backend.config.ts",
    "build:all": "npm run build && npm run build:backend",
    "start": "node dist/backend/startServer.js",
    "start:dev": "tsx src/backend/startServer.ts",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "test:providers": "tsx src/scripts/provider-live-test.ts"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/websocket": "^11.2.0",
    "@tanstack/react-query": "^5.101.0",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "firebase": "^11.3.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.25.1",
    "lru-cache": "^11.3.6",
    "lucide-react": "^0.300.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.22.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^1.5.0"
  }
}
