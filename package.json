    "technicals:compute": "tsx -e 'const {computeAndCache} = require(\"./src/backend/services/technicals/TechnicalIndicatorService\"); const s = process.argv.find(a=>a.startsWith(\"--symbols=\"))?.split(\"=\")[1]; Promise.all((s||\"RELIANCE,ITC\").split(\",\").map(async(sym)=>{const r=await computeAndCache(sym);console.log(sym+\": \"+Object.keys(r.indicators).filter(k=>r.indicators[k]!==null).length+\" indicators computed\")})).then(()=>process.exit(0)).catch(e=>{console.error(e);process.exit(1)})'",
