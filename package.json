    "test:release-gate": "vitest run scripts/__tests__/release-gate.test.ts",
    "test:provider-broker": "vitest run tests/providers src/services/providers/broker/*.test.ts src/backend/persistence/cache/cacheHierarchyEngine.test.ts",
