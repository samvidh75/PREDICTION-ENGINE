{
  "name": "prediction-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:frontend",
    "build:frontend": "npm run typecheck:frontend && vite build",
    "build:vercel": "npm run typecheck:vercel && vite build",
    "build:backend": "npm run typecheck:backend && npm run compile:backend",
    "build:render": "npm run compile:backend",
    "build:docker": "npm run compile:backend && npm run build:frontend",
    "build:all": "npm run build && npm run build:backend",
    "compile:backend": "tsc -p tsconfig.backend.emit.json && node scripts/fix-esm-imports.js",
    "start": "node dist/backend/backend/startServer.js",
    "start:dev": "tsx src/backend/startServer.ts",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "npm run typecheck:all",
    "typecheck:frontend": "tsc -p tsconfig.frontend.json --noEmit",
    "typecheck:vercel": "tsc -p tsconfig.frontend.json --noEmit",
    "typecheck:backend": "tsc -p tsconfig.backend.json --noEmit",
    "typecheck:active": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:all": "npm run typecheck:active",
    "typecheck:legacy": "tsc -p tsconfig.all.json --noEmit",
    "test": "vitest run",
    "test:unit": "node scripts/run-vitest-ci.mjs",
    "test:unit:ci": "node scripts/run-vitest-ci.mjs",
    "test:integration:sqlite": "cross-env NODE_ENV=test DB_ADAPTER=sqlite ALLOW_SQLITE_FALLBACK=true SQLITE_DB_PATH=tmp/integration-sqlite.db vitest run --config vitest.integration.config.ts",
    "test:e2e:uiux": "vitest run tests/e2e/uiux",
    "test:integration:postgres": "cross-env NODE_ENV=test DB_ADAPTER=postgres ALLOW_SQLITE_FALLBACK=false COOKIE_SECRET=test-only-ci-secret vitest run --config vitest.integration.config.ts",
    "test:integration:postgres:ci": "cross-env REQUIRE_POSTGRES_INTEGRATION=true NODE_ENV=test DB_ADAPTER=postgres ALLOW_SQLITE_FALLBACK=false COOKIE_SECRET=test-only-ci-secret vitest run --config vitest.integration.config.ts",
    "seed:ci": "tsx scripts/seed-ci-fixtures.ts",
    "test:watch": "vitest",
    "test:coverage": "node scripts/run-vitest-ci.mjs --coverage",
    "test:coverage:ci": "node scripts/run-vitest-ci.mjs --coverage",
    "preview": "vite preview",
    "validate:schema": "tsx scripts/validate-schema-contract.ts",
    "validate:data-integrity": "tsx scripts/validate-data-integrity.ts",
    "validate:query-schema": "tsx scripts/audit-query-schema-compatibility.ts",
    "validate:distributions": "tsx scripts/validate-sector-distributions.ts",
    "smoke:api": "tsx scripts/smoke-test-api.ts",
    "validate:api-states": "tsx scripts/smoke-test-api.ts",
    "validate:hygiene": "tsx scripts/validate-repository-hygiene.ts",
    "release:gate": "tsx scripts/release-gate.ts",
    "test:smoke": "vitest run scripts/__tests__/smoke-test-api.test.ts",
    "test:release-gate": "vitest run scripts/__tests__/release-gate.test.ts",
    "test:providers": "tsx src/scripts/provider-live-test.ts",
    "lint": "npm run lint:active",
    "lint:active": "eslint --quiet src/backend src/db src/services/auth src/services/FactorEngine.ts src/services/FeatureEngine.ts src/services/retention scripts/validate-schema-contract.ts scripts/audit-query-schema-compatibility.ts scripts/validate-data-integrity.ts scripts/validate-repository-hygiene.ts",
    "lint:fix": "eslint . --fix",
    "repair:invalid-prices": "tsx scripts/repair-invalid-prices.ts",
    "repair:prediction-registry": "tsx scripts/repair-prediction-registry.ts",
    "check:score-collapse": "tsx scripts/check-score-collapse.ts",
    "pipeline:predictions": "tsx scripts/run-prediction-pipeline.ts",
    "ingest:fundamentals": "tsx scripts/ingest-fundamentals.ts"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/websocket": "^11.2.0",
    "@tanstack/react-query": "^5.101.0",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "firebase": "^11.3.0",
    "firebase-admin": "^14.0.0",
    "framer-motion": "^12.25.1",
    "lru-cache": "^11.3.6",
    "lucide-react": "^0.300.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.20",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.22.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
