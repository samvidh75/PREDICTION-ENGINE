# ── StockStory India — Production Environment ───────────────────────────────
# 100% FREE stack — no paid API keys needed
# Copy to .env.production and fill in secrets:
#   cp .env.prod .env.production
#   edit .env.production to set DB_PASSWORD_PROD, etc.

NODE_ENV=production

# ── Ollama (FREE — replaces OpenAI API) ─────────────────────────────────────
OLLAMA_URL=http://stockstory_ollama:11434
OLLAMA_MODEL=llama3.1:7b-instruct-q4_K_M

# ── Qdrant (FREE — replaces Pinecone) ───────────────────────────────────────
QDRANT_URL=http://stockstory_qdrant:6333

# ── Prometheus (FREE — replaces DataDog) ────────────────────────────────────
PROMETHEUS_URL=http://stockstory_prometheus:9090

# ── Grafana (FREE — replaces DataDog dashboards) ────────────────────────────
GRAFANA_URL=http://stockstory_grafana:3001

# ── PostgreSQL (FREE — Railway includes one) ────────────────────────────────
DATABASE_URL=postgresql://stockstory:${DB_PASSWORD_PROD}@stockstory_postgres:5432/stockstory
POSTGRES_DB=stockstory
POSTGRES_USER=stockstory
POSTGRES_PASSWORD=${DB_PASSWORD_PROD}

# ── Redis (FREE — Railway includes one) ─────────────────────────────────────
REDIS_URL=redis://stockstory_redis:6379
REDIS_PASSWORD=

# ── Backend ─────────────────────────────────────────────────────────────────
PORT=4001
HOST=0.0.0.0
COOKIE_SECRET=${COOKIE_SECRET}
LOG_LEVEL=info

# ── No paid API keys needed ─────────────────────────────────────────────────
# OpenAI, Pinecone, DataDog are ALL replaced by free services.
