# ╔══════════════════════════════════════════════════════════╗
# ║  SSI PRODUCTION ENVIRONMENT — TRACK-66 AGENT B         ║
# ║  Copy to .env.production and fill in real values       ║
# ╚══════════════════════════════════════════════════════════╝

# ── Database ─────────────────────────────────────────────────
# SQLite (default): leave DATABASE_URL blank to use SQLite
# PostgreSQL: postgresql://user:password@host:5432/stockstory
DATABASE_URL=
DB_PATH=./data/stockstory.db
# Adapter: 'postgres' or 'sqlite' (default). Production should use postgres.
DB_ADAPTER=postgres
# Database policy — set false in production to prevent accidental SQLite fallback
ALLOW_SQLITE_FALLBACK=false
ALLOW_SQLITE_IN_PRODUCTION=false

# ── Firebase (Authentication) ─────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ── Alerting Channels ─────────────────────────────────────────
# Slack webhook (optional)
SLACK_WEBHOOK_URL=

# Discord webhook (optional)
DISCORD_WEBHOOK_URL=

# Email SMTP (optional — only CRITICAL alerts via email)
ALERT_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@stockstory.in
ALERT_EMAIL_TO=admin@stockstory.in

# ── API Keys (Optional Providers) ────────────────────────────
# Yahoo Finance / yfinance research bridge.
# Enabled for production with rate-limiting best practices.
YFINANCE_ENABLED=true
YFINANCE_CACHE_PATH=tmp/yfinance-cache.json
YFINANCE_CACHE_SECONDS=3600
YFINANCE_REQUEST_CACHE_ENABLED=false
YFINANCE_REQUEST_CACHE_NAME=tmp/yfinance-http-cache
YFINANCE_BATCH_SIZE=40
YFINANCE_DOWNLOAD_TIMEOUT_SECONDS=15
YFINANCE_MIN_DELAY_SECONDS=2.0
YFINANCE_MAX_DELAY_SECONDS=4.0

# Finnhub fundamentals and company profile provider.
# FINNHUB_KEY is the preferred backend variable.
# FINNHUB_API_KEY remains accepted as a compatibility alias.
FINNHUB_KEY=
FINNHUB_API_KEY=

# IndianAPI.in quote, metadata, and historical-price provider.
# Configure only after confirming the deployment account and permitted usage.
INDIANAPI_KEY=



# ── Upstox (Optional — for live trading integration & fundamentals) ──
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:5173/auth/upstox/callback
# Server-to-server Upstox access token (bypasses user OAuth for fundamentals)
UPSTOX_ACCESS_TOKEN=

# ── Security ──────────────────────────────────────────────────
# Generate: openssl rand -base64 64
COOKIE_SECRET=

# ── Server ───────────────────────────────────────────────────
# Backend port — Render injects PORT automatically; 4001 is the dev default
PORT=4001
NODE_ENV=production
HOST=0.0.0.0

# ── Pipeline ─────────────────────────────────────────────────
PIPELINE_LOCK_TIMEOUT_MS=3600000
PIPELINE_MAX_RETRIES=3
DATA_FRESHNESS_STALE_DAYS=2
DATA_FRESHNESS_CRITICAL_DAYS=7

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_MAX=20
RATE_LIMIT_REDIS_REQUIRED=true
RATE_LIMIT_SINGLE_INSTANCE_ALLOWED=false

# ── Provider Broker ──────────────────────────────────────────
REDIS_URL=
PROVIDER_BROKER_ENABLED=true
PROVIDER_BROKER_REDIS_REQUIRED=true
PROVIDER_BROKER_SINGLE_INSTANCE_ALLOWED=false
MAX_PROVIDER_CALLS_PER_RUN=500

# ── Feature Flags ────────────────────────────────────────────
ENABLE_PREDICTION_FACTORY=true
ENABLE_OUTCOME_VALIDATOR=true
ENABLE_DAILY_FEED=true
ENABLE_TRUST_CENTRE=true
ENABLE_ALERTING=true
ENABLE_RATE_LIMITING=true

# ── F5: Unified Prediction Engine ──────────────────────
# Set to 'true' to enable the unified engine as the authoritative scorer
UNIFIED_PREDICTION_ENGINE_ENABLED=false
# Set to 'true' to run unified engine alongside legacy (no persist)
UNIFIED_PREDICTION_ENGINE_SHADOW_MODE=false
# Delegate scoreSnapshot() to unified engine (requires UNIFIED_PREDICTION_ENGINE_ENABLED=true)
F5_SCORE_SNAPSHOT_DELEGATE=false
# Delegate PredictionFactory to unified engine (requires UNIFIED_PREDICTION_ENGINE_ENABLED=true)
F5_PREDICTION_FACTORY_DELEGATE=false
# Confirmation env var for apply mode
CONFIRM_UNIFIED_ENGINE_APPLY=false
# Unified engine model version (auto-generated, override for pinning)
UNIFIED_ENGINE_MODEL_VERSION=unified-v1.0.0
