# ╔════════════════════════════════════════════════════════════════════════╗
# ║  StockStory India — PRODUCTION Environment Variable Reference         ║
# ║  Complete inventory of all env vars required/set in production.       ║
# ║  Values are configured via:                                           ║
# ║   ├─ Vercel Dashboard (frontend + api/* serverless)                   ║
# ║   ├─ Render Dashboard (backend Fastify server)                        ║
# ║   └─ Neon / Upstash dashboards (infrastructure)                       ║
# ║  NEVER commit live secret values.                                     ║
# ╚════════════════════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════════════════════════
# VERCEL — Frontend (SPA) + API serverless functions
# ═══════════════════════════════════════════════════════════════════════════════

# ── Domain / Routing ──────────────────────────────────────────────────────────
VITE_APP_DOMAIN=stockstory-india.com
VITE_API_DOMAIN=www.stockstory-india.com
VITE_APP_ORIGIN=https://www.stockstory-india.com
VITE_API_BASE_URL=https://www.stockstory-india.com/api

# ── Firebase Auth (Client SDK) ──────────────────────────────────────────────
VITE_FIREBASE_API_KEY=set-in-vercel-dashboard
VITE_FIREBASE_AUTH_DOMAIN=stockstory-india.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=stockstory-india
VITE_FIREBASE_STORAGE_BUCKET=stockstory-india.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=set-in-vercel-dashboard
VITE_FIREBASE_APP_ID=set-in-vercel-dashboard

# ── Google Auth ─────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=set-in-vercel-dashboard

# ── Market Data (used by api/* functions) ───────────────────────────────────
VITE_INDIANAPI_KEY=set-in-vercel-dashboard
INDIANAPI_KEY=set-in-vercel-dashboard
FINNHUB_KEY=set-in-vercel-dashboard
ALPHA_VANTAGE_KEY=set-in-vercel-dashboard
NEWS_API_KEY=set-in-vercel-dashboard

# ── Upstox (Broker integration) ─────────────────────────────────────────────
VITE_UPSTOX_CLIENT_ID=set-in-vercel-dashboard
VITE_UPSTOX_REDIRECT_URI=set-in-vercel-dashboard
UPSTOX_ACCESS_TOKEN=set-in-vercel-dashboard
UPSTOX_CLIENT_SECRET=set-in-vercel-dashboard
UPSTOX_API_KEY=set-in-vercel-dashboard

# ── Groq LLM (used by frontend) ─────────────────────────────────────────────
VITE_GROQ_API_KEY=set-in-vercel-dashboard

# ── Supabase (used by frontend) ─────────────────────────────────────────────
VITE_SUPABASE_URL=set-in-vercel-dashboard
VITE_SUPABASE_ANON_KEY=set-in-vercel-dashboard

# ── Database (used by api/* serverless functions) ───────────────────────────
DATABASE_URL=postgresql://set-in-vercel-dashboard
REDIS_URL=rediss://set-in-vercel-dashboard

# ── Feature Flags ───────────────────────────────────────────────────────────
VITE_SCREENER_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# RENDER — Backend Fastify Server (DB, WebSocket, LLM, Workers)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
HOST=0.0.0.0
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://set-in-render-dashboard
DB_ADAPTER=postgres
ALLOW_SQLITE_FALLBACK=false
ALLOW_SQLITE_IN_PRODUCTION=false
FORCE_MIGRATIONS=true

# ── Security ──────────────────────────────────────────────────────────────────
COOKIE_SECRET=set-in-render-dashboard

# ── Redis (optional — backend degrades gracefully) ───────────────────────────
REDIS_URL=rediss://set-in-render-dashboard

# ── CORS ──────────────────────────────────────────────────────────────────────
EXTRA_ALLOWED_ORIGINS=https://stockstory-india.com

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=stockstory-india
FIREBASE_CLIENT_EMAIL=set-in-render-dashboard
FIREBASE_PRIVATE_KEY=set-in-render-dashboard
FIREBASE_USE_APPLICATION_DEFAULT_CREDENTIALS=false

# ── Market Data ──────────────────────────────────────────────────────────────
INDIANAPI_KEY=set-in-render-dashboard

# ── Upstox ────────────────────────────────────────────────────────────────────
UPSTOX_ACCESS_TOKEN=set-in-render-dashboard
UPSTOX_CLIENT_SECRET=set-in-render-dashboard

# ── LLM / AI (optional — backend uses deterministic factor-engine fallback) ──
# Production uses either an external API key or the built-in deterministic
# research provider. Ollama/SGLang are local-only and require LOCAL_AI_ENABLED=true.
LOCAL_AI_ENABLED=false
SGLANG_URL=
OLLAMA_URL=
ENABLE_RESEARCH_BOT=true
ENABLE_SCORE_EXPLANATIONS=true
ENABLE_STOCK_SNAPSHOTS=true
ENABLE_STOCK_COMPARISON=true
ENABLE_SCANNER_THESES=true
ENABLE_THESIS_TRACKING=true

# ── Groq LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=set-in-render-dashboard
GROQ_MODEL=llama-3.1-8b-instant

# ── Public NSE Providers ──────────────────────────────────────────────────────
JUGAD_DATA_ENABLED=true
NSEPYTHON_ENABLED=true
PUBLIC_NSE_PROVIDER_TIMEOUT_MS=30000
PUBLIC_MARKET_BROKER_ENABLED=true
PUBLIC_MARKET_BROKER_TIMEOUT_MS=30000
YAHOO_ENABLED=false

# ── Yahoo Finance ─────────────────────────────────────────────────────────────
YFINANCE_ENABLED=true
YFINANCE_CACHE_PATH=tmp/yfinance-cache.json
YFINANCE_CACHE_SECONDS=3600
YFINANCE_BATCH_SIZE=40
YFINANCE_DOWNLOAD_TIMEOUT_SECONDS=15
YFINANCE_MIN_DELAY_SECONDS=2.0
YFINANCE_MAX_DELAY_SECONDS=4.0

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_PREDICTION_FACTORY=true
ENABLE_OUTCOME_VALIDATOR=true
ENABLE_DAILY_FEED=true
ENABLE_TRUST_CENTRE=true
ENABLE_ALERTING=true
ENABLE_RATE_LIMITING=true

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_LOCK_TIMEOUT_MS=3600000
PIPELINE_MAX_RETRIES=3
DATA_FRESHNESS_STALE_DAYS=2
DATA_FRESHNESS_CRITICAL_DAYS=7

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_MAX=20
RATE_LIMIT_REDIS_REQUIRED=true
PROVIDER_BROKER_ENABLED=true
PROVIDER_BROKER_REDIS_REQUIRED=true
MAX_PROVIDER_CALLS_PER_RUN=500

# ── Alerting ──────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=set-in-render-dashboard
DISCORD_WEBHOOK_URL=set-in-render-dashboard
ALERT_EMAIL_ENABLED=false

# ── Franchise ─────────────────────────────────────────────────────────────────
STOCKSTORY_FRANCHISE_BRAND=india

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=set-in-render-dashboard
GRAFANA_URL=set-in-render-dashboard

# ── Public Fundamentals ──────────────────────────────────────────────────────
PUBLIC_FUNDAMENTALS_ENABLED=false
CSV_FUNDAMENTALS_PATH=./data/fundamentals
