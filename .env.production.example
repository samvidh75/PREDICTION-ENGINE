# ── REQUIRED — backend will not start without these ──────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=10000
DATABASE_URL=postgresql://user:pass@ep-xxxx.region.neon.tech/neondb?sslmode=require
COOKIE_SECRET=run-openssl-rand-base64-64
DB_ADAPTER=postgres

# ── STRONGLY RECOMMENDED ─────────────────────────────────────────────────
LOG_LEVEL=info
FORCE_MIGRATIONS=true
ALLOW_SQLITE_FALLBACK=false
ALLOW_SQLITE_IN_PRODUCTION=false
EXTRA_ALLOWED_ORIGINS=https://stockstory-india.com

# ── Redis (optional — backend uses in-memory cache when absent) ──────────
# REDIS_URL=redis://default:pass@xxxx.upstash.io:6379

# ── SGLang / LLM (optional — AI features degrade when absent) ────────────
# SGLANG_URL=http://your-sglang-service:8000
ENABLE_SGLANG=false
ENABLE_RESEARCH_BOT=true
ENABLE_SCORE_EXPLANATIONS=true
ENABLE_STOCK_SNAPSHOTS=true
ENABLE_STOCK_COMPARISON=true
ENABLE_SCANNER_THESES=true
ENABLE_THESIS_TRACKING=true

# ── Market Data (optional — required for live provider data) ─────────────
# INDIANAPI_KEY=your-api-key

# ── Firebase (optional — required for auth) ──────────────────────────────
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_USE_APPLICATION_DEFAULT_CREDENTIALS=false

# ── Upstox (optional — for broker integration) ───────────────────────────
# UPSTOX_ACCESS_TOKEN=your-access-token
# UPSTOX_CLIENT_SECRET=your-client-secret

# ── Frontend (Vite public vars set in Vercel) ────────────────────────────
VITE_API_BASE_URL=https://stockstory-api.onrender.com
VITE_APP_DOMAIN=stockstory-india.com
VITE_API_DOMAIN=stockstory-api.onrender.com
VITE_APP_ORIGIN=https://stockstory-india.com
