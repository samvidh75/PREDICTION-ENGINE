# ─────────────────────────────────────────────────────────────────────────────
# StockStory India — Production Environment Template
# Copy to .env.production and fill every value before deploying.
# NEVER commit .env.production to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain ──────────────────────────────────────────────────────────────────
VITE_APP_DOMAIN=stockstory-india.com
VITE_API_DOMAIN=stockstory-india.com
VITE_APP_ORIGIN=https://stockstory-india.com
VITE_API_BASE_URL=https://stockstory-india.com/api

# ── Google OAuth ────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=220040399044-p983i5ba82sltju4k9dn9141kksr1rhc.apps.googleusercontent.com

# ── Firebase ─────────────────────────────────────────────────────────────────
# Known values (safe to set as-is):
VITE_FIREBASE_AUTH_DOMAIN=stockstory-india.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=stockstory-india
VITE_FIREBASE_STORAGE_BUCKET=stockstory-india.firebasestorage.app
# Get from: https://console.firebase.google.com/project/stockstory-india/settings/general
VITE_FIREBASE_API_KEY=AIzaSyCOlke_L6Si3KEuqQxDIG9ZUUf4R4RcId8
VITE_FIREBASE_MESSAGING_SENDER_ID=1050723709235
VITE_FIREBASE_APP_ID=1:1050723709235:web:f33512721e75102b2c8e46

# ── Backend / Server ─────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4001
HOST=0.0.0.0

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
COOKIE_SECRET=GENERATE_A_STRONG_RANDOM_SECRET_HERE

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/stockstory

# ── External APIs ─────────────────────────────────────────────────────────────
