{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "types": ["vite/client", "vitest/globals", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/components/HealthometerWidget.jsx",
    "src/components/MarketHydrator.jsx",
    "src/views/PracticeTerminal.jsx",
    "src/scripts/calibrate.ts",
    "src/scripts/calibrate_v2.ts",
    "src/scripts/run-explainability-pipeline.ts",
    "src/components/intelligence/ResponsiveUIScalingLayer.tsx",
    "**/*.bak.ts",
    "**/*.deprecated.ts",
    "scripts/adaptive-calibration.ts",
    "scripts/backtesting-framework.ts",
    "scripts/factor-quality-audit.ts",
    "scripts/fundamental-completion.ts",
    "scripts/fundamental-integration.ts",
    "scripts/institutional-backtesting.ts",
    "scripts/institutional-ranking-validator.ts",
    "scripts/rc-upstox-001.ts",
    "scripts/real-backtesting-framework.ts",
    "scripts/real-financial-integration.ts",
    "scripts/reproduce_all_claims.ts",
    "scripts/revalidation-backtest.ts",
    "scripts/track-7e-live-fundamental-activation.ts",
    "scripts/track-7g-yahoo-fundamentals.ts",
    "scripts/track-7h-portfolio-intelligence.ts",
    "scripts/track-8a-fundamentals.ts",
    "scripts/track-9a-fundamental-influence.ts"
  ]
}
