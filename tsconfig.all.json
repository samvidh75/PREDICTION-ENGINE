{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "types": ["vite/client", "vitest/globals", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/components/HealthometerWidget.jsx",
    "src/components/MarketHydrator.jsx",
    "src/views/PracticeTerminal.jsx",
    "src/scripts/calibrate.ts",
    "src/scripts/calibrate_v2.ts",
    "src/scripts/run-explainability-pipeline.ts",
    "src/components/intelligence/ResponsiveUIScalingLayer.tsx",
    "**/*.bak.ts",
    "**/*.deprecated.ts"
  ]
}
