{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infrastructure/sglang-server/Dockerfile.cpu"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  },
  "services": [
    {
      "name": "sglang-server",
      "port": 30000,
      "cpu": 4,
      "memory": 8192,
      "volumes": [
        {
          "mountPath": "/models",
          "name": "model-cache"
        }
      ]
    }
  ]
}
