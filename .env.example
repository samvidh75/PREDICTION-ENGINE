# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/stockstory

# ── Redis (platform-agnostic: Railway, Vercel, Render, Fly, any) ──
# REDIS_URL is the PRIMARY Redis connection string. Set this on every deployment.
# Use rediss:// for TLS (Upstash, Redis Cloud). Example:
#   REDIS_URL="rediss://default:<password>@<host>.upstash.io:6379"
# Supported providers: Upstash, Redis Cloud, Railway Valkey, any Redis-compatible.
# If REDIS_URL is unset, the app falls back to in-memory caches (single-instance only).
REDIS_URL=

# Optional — Upstash REST API vars (non-TLS alternative, only if `rediss://` is unavailable)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Provider API Keys ─────────────────────────────────────────
# IndianAPI.in — ₹399 subscription (quotes, metadata, fundamentals)
INDIANAPI_KEY=

# Upstox OAuth credentials (market data, fundamentals, instruments)
UPSTOX_API_KEY=
UPSTOX_CLIENT_SECRET=
UPSTOX_ACCESS_TOKEN=
UPSTOX_REDIRECT_URI=https://your-domain.com/api/providers/upstox/callback

# Finnhub — REMOVED from active production pipeline (key kept for historical reference)
# FINNHUB_KEY=

# ── Security ──────────────────────────────────────────────────
COOKIE_SECRET=

# ── Firebase Authentication — Frontend (VITE_*) ─────────────────
# Public Firebase config — safe to commit (project identifiers only).
# These are served to the browser and required for auth to work.
# Get values from: Firebase Console → Project Settings → General → Your apps → Web
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=    (optional — for Analytics)

# ── Firebase Authentication — Backend only ──────────────────────
# Not exposed to the frontend. Set these in Railway/self-hosted env.
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=

# ── Frontend (more VITE env vars — set on Vercel for production) ──
# VITE_API_BASE_URL=https://stockstory-india.com/api
# VITE_APP_DOMAIN=stockstory-india.com
# VITE_API_DOMAIN=stockstory-india.com
# VITE_APP_ORIGIN=https://stockstory-india.com
# These default correctly for production; override only if different.

# ── Server ───────────────────────────────────────────────────
PORT=4001
HOST=0.0.0.0
NODE_ENV=production
