# ── Backend (Render) ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
HOST=0.0.0.0
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require
COOKIE_SECRET=generate-with-openssl-rand-base64-64
DB_ADAPTER=postgres
ALLOW_SQLITE_FALLBACK=false
ALLOW_SQLITE_IN_PRODUCTION=false
FORCE_MIGRATIONS=true
LOG_LEVEL=info
EXTRA_ALLOWED_ORIGINS=https://stockstory-india.com

# ── Frontend (Vercel) — Vite public vars ─────────────────────────────────────
VITE_API_BASE_URL=https://stockstory-api.onrender.com
VITE_APP_DOMAIN=stockstory-india.com
VITE_API_DOMAIN=stockstory-api.onrender.com
VITE_APP_ORIGIN=https://stockstory-india.com

# ── Firebase (optional — required for auth) ──────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
