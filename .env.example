# ╔══════════════════════════════════════════════════════════╗
# ║  SSI ENVIRONMENT VARIABLE REFERENCE                     ║
# ║  Complete inventory of all env vars in the project.     ║
# ║  Keep this file in sync with Railway and Vercel.        ║
# ╚══════════════════════════════════════════════════════════╝

# ── Node/Server ─────────────────────────────────────────────────
NODE_ENV=production
PORT=4001
HOST=0.0.0.0

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
# Railway provides POSTGRES_PASSWORD; reference it as ${POSTGRES_PASSWORD}
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/stockstory
DB_PATH=./data/stockstory.db
# Adapter: 'postgres' or 'sqlite' (production MUST be postgres)
DB_ADAPTER=postgres
# Safety flags — set false in production
ALLOW_SQLITE_FALLBACK=false
ALLOW_SQLITE_IN_PRODUCTION=false

# ── Redis (platform-agnostic: Railway, Vercel, Render, Fly, any) ──
# REDIS_URL is the PRIMARY Redis connection string.
# Use rediss:// for TLS (Upstash, Redis Cloud).
REDIS_URL=rediss://default:${REDIS_PASSWORD}@REPLACE_WITH_UPSTASH_HOST:6379

# ── Security ──────────────────────────────────────────────────
# Generate: openssl rand -base64 64
COOKIE_SECRET=

# ── Firebase Admin SDK (token verification) ──────────────────────
# Required for verifying Firebase ID tokens server-side.
# Get values from: Firebase Console → Project Settings → Service accounts
FIREBASE_PROJECT_ID=stockstory-india
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@stockstory-india.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
# ^ The private key must use \n for newlines — one quoted line with \n escapes.
FIREBASE_USE_APPLICATION_DEFAULT_CREDENTIALS=false

# ── Provider Credentials ────────────────────────────────────────
# IndianAPI.in — ₹399 subscription (quotes, metadata, fundamentals)
# Already configured in Railway environment.
INDIANAPI_KEY=sk-live-a6KsuNo6hEAm9q9mTT0cmFqM18pRViLkhbEr1tQ2

# Finnhub — REMOVED from active production pipeline (kept for legacy)
# FINNHUB_KEY=
# FINNHUB_API_KEY=

# ── Public NSE Provider Config (no credentials needed) ─────────
# These providers access public NSE data without any credentials.
# Set 'true' to enable, 'false' to disable.
JUGAD_DATA_ENABLED=true
NSELIB_ENABLED=false            # Requires Python 3.10+ (unavailable on 3.9)
NSEPYTHON_ENABLED=true
PUBLIC_NSE_PROVIDER_TIMEOUT_MS=30000

# ── Public Market Provider Broker ─────────────────────────────
PUBLIC_MARKET_BROKER_ENABLED=true
PUBLIC_MARKET_BROKER_TIMEOUT_MS=30000

# ── Yahoo Finance (blocked from India — 429 rate-limited) ─────
# Yahoo is geo-blocked / rate-limited from most Indian IPs.
# Disabled in production. Only enable locally for testing.
YAHOO_ENABLED=false

# ── Public Fundamentals (not yet automatic) ────────────────────
# nsepython.nse_results() returns empty; nselib needs Python 3.10+.
# Automatic fundamentals not available yet — use CSV import.
PUBLIC_FUNDAMENTALS_ENABLED=false
# CSV import path for manual fundamentals override
CSV_FUNDAMENTALS_PATH=./data/fundamentals

# ── Alerting Channels (optional) ────────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
ALERT_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@stockstory.in
ALERT_EMAIL_TO=admin@stockstory.in

# ── Pipeline ─────────────────────────────────────────────────
PIPELINE_LOCK_TIMEOUT_MS=3600000
PIPELINE_MAX_RETRIES=3
DATA_FRESHNESS_STALE_DAYS=2
DATA_FRESHNESS_CRITICAL_DAYS=7

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_MAX=20
RATE_LIMIT_REDIS_REQUIRED=true
RATE_LIMIT_SINGLE_INSTANCE_ALLOWED=false

# ── Provider Broker ──────────────────────────────────────────
PROVIDER_BROKER_ENABLED=true
PROVIDER_BROKER_REDIS_REQUIRED=true
PROVIDER_BROKER_SINGLE_INSTANCE_ALLOWED=false
MAX_PROVIDER_CALLS_PER_RUN=500

# ── Feature Flags ────────────────────────────────────────────
ENABLE_PREDICTION_FACTORY=true
ENABLE_OUTCOME_VALIDATOR=true
ENABLE_DAILY_FEED=true
ENABLE_TRUST_CENTRE=true
ENABLE_ALERTING=true
ENABLE_RATE_LIMITING=true

# ── F5: Unified Prediction Engine ──────────────────────────
UNIFIED_PREDICTION_ENGINE_ENABLED=false
UNIFIED_PREDICTION_ENGINE_SHADOW_MODE=false
F5_SCORE_SNAPSHOT_DELEGATE=false
F5_PREDICTION_FACTORY_DELEGATE=false
CONFIRM_UNIFIED_ENGINE_APPLY=false
UNIFIED_ENGINE_MODEL_VERSION=unified-v1.0.0

# ── Franchise Labels/Flags ─────────────────────────────────────
STOCKSTORY_FRANCHISE_BRAND=india

# ── Frontend (VITE_* — set on Vercel for production) ────────────
# Public Firebase config — safe to commit (project identifiers only)
VITE_FIREBASE_API_KEY=AIzaSyCOlke_L6Si3KEuqQxDIG9ZUUf4R4RcId8
VITE_FIREBASE_AUTH_DOMAIN=stockstory-india.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=stockstory-india
VITE_FIREBASE_STORAGE_BUCKET=stockstory-india.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1050723709235
VITE_FIREBASE_APP_ID=1:1050723709235:web:f33512721e75102b2c8e46
# VITE_FIREBASE_MEASUREMENT_ID=    (optional — for Analytics)

