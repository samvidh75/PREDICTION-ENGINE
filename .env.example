# ╔════════════════════════════════════════════════════════════════════════╗
# ║  StockStory India — Environment Variable Reference                    ║
# ║  Complete inventory of all env vars used across the app.              ║
# ║  ├─ Frontend (Vite/Vercel)     — all VITE_* vars                      ║
# ║  ├─ API (Vercel serverless)    — backend api/* functions              ║
# ║  └─ Backend (Render/Fastify)   — persistent server for DB/WS/LLM     ║
# ╚════════════════════════════════════════════════════════════════════════╝

# ── REQUIRED: Node/Runtime ────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
HOST=0.0.0.0
LOG_LEVEL=info

# ── REQUIRED: Database (PostgreSQL via Neon) ──────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxxx.region.neon.tech/neondb?sslmode=require
DB_ADAPTER=postgres
ALLOW_SQLITE_FALLBACK=false
ALLOW_SQLITE_IN_PRODUCTION=false
FORCE_MIGRATIONS=true
DB_PATH=./data/stockstory.db

# ── REQUIRED: Session Security ────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
COOKIE_SECRET=

# ── REQUIRED: Frontend Domain Config (Vite — set in Vercel) ──────────────────
VITE_APP_DOMAIN=stockstory-india.com
VITE_API_DOMAIN=www.stockstory-india.com
VITE_APP_ORIGIN=https://www.stockstory-india.com
VITE_API_BASE_URL=https://www.stockstory-india.com/api

# ── OPTIONAL: Redis (Upstash — for caching, rate limiting, provider broker) ──
REDIS_URL=rediss://default:password@xxxx.upstash.io:6379

# ── OPTIONAL: LLM / AI (SGLang) ──────────────────────────────────────────────
SGLANG_URL=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
ENABLE_SGLANG=false
ENABLE_RESEARCH_BOT=true
ENABLE_SCORE_EXPLANATIONS=true
ENABLE_STOCK_SNAPSHOTS=true
ENABLE_STOCK_COMPARISON=true
ENABLE_SCANNER_THESES=true
ENABLE_THESIS_TRACKING=true

# ── OPTIONAL: Firebase Auth (Admin SDK — for token verification) ──────────────
FIREBASE_PROJECT_ID=stockstory-india
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@stockstory-india.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_USE_APPLICATION_DEFAULT_CREDENTIALS=false

# ── OPTIONAL: Firebase Auth (Client SDK — set in Vercel) ────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=stockstory-india.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=stockstory-india
VITE_FIREBASE_STORAGE_BUCKET=stockstory-india.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── OPTIONAL: Google Auth ────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=

# ── OPTIONAL: Market Data Providers ──────────────────────────────────────────
INDIANAPI_KEY=
VITE_INDIANAPI_KEY=
FINNHUB_KEY=
ALPHA_VANTAGE_KEY=
NEWS_API_KEY=

# ── OPTIONAL: Upstox Broker Integration ──────────────────────────────────────
UPSTOX_ACCESS_TOKEN=
UPSTOX_CLIENT_SECRET=
UPSTOX_API_KEY=
VITE_UPSTOX_CLIENT_ID=
VITE_UPSTOX_REDIRECT_URI=
UPSTOX_SANDBOX_ENABLED=false
UPSTOX_SANDBOX_MODE=false

# ── OPTIONAL: Groq LLM (free, replaces OpenAI) ──────────────────────────────
VITE_GROQ_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── OPTIONAL: Supabase ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── OPTIONAL: CORS ────────────────────────────────────────────────────────────
EXTRA_ALLOWED_ORIGINS=https://stockstory-india.com

# ── OPTIONAL: Public NSE Providers (no credentials needed) ───────────────────
JUGAD_DATA_ENABLED=true
NSEPYTHON_ENABLED=true
PUBLIC_NSE_PROVIDER_TIMEOUT_MS=30000
PUBLIC_PROVIDER_HEALTH_TIMEOUT_MS=6000
PUBLIC_MARKET_BROKER_ENABLED=true
PUBLIC_MARKET_BROKER_TIMEOUT_MS=30000

# ── OPTIONAL: Yahoo Finance ───────────────────────────────────────────────────
YAHOO_ENABLED=false
YFINANCE_ENABLED=true
YFINANCE_CACHE_PATH=tmp/yfinance-cache.json
YFINANCE_CACHE_SECONDS=3600
YFINANCE_BATCH_SIZE=40
YFINANCE_DOWNLOAD_TIMEOUT_SECONDS=15
YFINANCE_MIN_DELAY_SECONDS=2.0
YFINANCE_MAX_DELAY_SECONDS=4.0

# ── OPTIONAL: Feature Flags ──────────────────────────────────────────────────
ENABLE_PREDICTION_FACTORY=true
ENABLE_OUTCOME_VALIDATOR=true
ENABLE_DAILY_FEED=true
ENABLE_TRUST_CENTRE=true
ENABLE_ALERTING=true
ENABLE_RATE_LIMITING=true

# ── OPTIONAL: Pipeline & Rate Limiting ──────────────────────────────────────
PIPELINE_LOCK_TIMEOUT_MS=3600000
PIPELINE_MAX_RETRIES=3
DATA_FRESHNESS_STALE_DAYS=2
DATA_FRESHNESS_CRITICAL_DAYS=7
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_MAX=20
RATE_LIMIT_REDIS_REQUIRED=true
RATE_LIMIT_SINGLE_INSTANCE_ALLOWED=false
PROVIDER_BROKER_ENABLED=true
PROVIDER_BROKER_REDIS_REQUIRED=true
PROVIDER_BROKER_SINGLE_INSTANCE_ALLOWED=false
MAX_PROVIDER_CALLS_PER_RUN=500

# ── OPTIONAL: Alerting ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
ALERT_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@stockstory.in
ALERT_EMAIL_TO=admin@stockstory.in

# ── OPTIONAL: Screener ────────────────────────────────────────────────────────
VITE_SCREENER_ENABLED=true
SCREENER_RATE_LIMIT_MS=12000
CACHE_TTL_MS=300000

# ── OPTIONAL: Market Timezone ─────────────────────────────────────────────────
MARKET_TIMEZONE=Asia/Kolkata
MARKET_OPEN=09:30
MARKET_CLOSE=15:30

# ── OPTIONAL: Franchise / Monitoring ─────────────────────────────────────────
STOCKSTORY_FRANCHISE_BRAND=india
PROMETHEUS_URL=
GRAFANA_URL=
QDRANT_URL=
PUBLIC_FUNDAMENTALS_ENABLED=false
CSV_FUNDAMENTALS_PATH=./data/fundamentals
