{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "sourceMap": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/backend/**/*",
    "src/db/**/*",
    "src/intelligence/SignalValidationEngine.ts",
    "src/intelligence/PredictionDiffEngine.ts",
    "src/intelligence/AttentionEngine.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts"
  ]
}
