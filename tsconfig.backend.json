{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "declaration": false
  },
  "include": [
    "src/render/**/*",
    "src/db/**/*",
    "src/intelligence/SignalValidationEngine.ts",
    "src/intelligence/PredictionDiffEngine.ts",
    "src/intelligence/AttentionEngine.ts",
    "src/intelligence/PredictionExplanationEngine.ts",
    "src/intelligence/SignalFeedEngine.ts",
    "src/intelligence/DataFreshnessEngine.ts",
    "src/services/FeatureEngine.ts",
    "src/services/FactorEngine.ts",
    "src/services/providers/MoneycontrolQuoteProvider.ts",
    "src/services/ExplanationEngine.ts",
    "src/services/intelligence/types.ts",
    "src/services/intelligence/engines/FinancialEngine/QualityScoring.ts",
    "src/services/intelligence/engines/FinancialEngine/GrowthScoring.ts",
    "src/services/intelligence/engines/FinancialEngine/DebtScoring.ts",
    "src/services/intelligence/engines/FinancialEngine/index.ts",
    "src/services/intelligence/engines/TechnicalEngine/MomentumScoring.ts",
    "src/services/intelligence/engines/TechnicalEngine/TrendScoring.ts",
    "src/services/intelligence/engines/TechnicalEngine/VolatilityScoring.ts",
    "src/services/intelligence/engines/TechnicalEngine/index.ts",
    "src/middleware/RateLimiter.ts",
    "src/validation/PredictionAccuracyEngine.ts",
    "src/validation/ModelHealthEngine.ts",
    "src/validation/SectorDriftEngine.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
