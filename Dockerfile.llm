# ─────────────────────────────────────────────────────────────────────────────
# StockEx LLM Service - Ollama with Fine-Tuned Models
# ─────────────────────────────────────────────────────────────────────────────

FROM ollama/ollama:latest

WORKDIR /app

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Copy fine-tuned LoRA adapter
COPY ./stockex_slm_agent_output /root/.ollama/models/stockex_slm_agent_output

# Set Ollama environment
ENV OLLAMA_HOST=0.0.0.0:11434
ENV OLLAMA_NUM_GPU=0
ENV OLLAMA_NUM_THREAD=4

# Create startup script
RUN echo '#!/bin/bash\n\
# Start Ollama in background\n\
ollama serve &\n\
OLLAMA_PID=$!\n\
\n\
# Wait for Ollama to be ready\n\
echo "Waiting for Ollama to start..."\n\
for i in {1..30}; do\n\
  if curl -s http://localhost:11434/api/tags > /dev/null 2>&1; then\n\
    echo "Ollama ready!"\n\
    break\n\
  fi\n\
  echo "Attempt $i/30..."\n\
  sleep 1\n\
done\n\
\n\
# Pull base models if not exists\n\
echo "Checking for models..."\n\
if ! ollama list | grep -q qwen2.5:0.5b; then\n\
  echo "Pulling Qwen2.5:0.5b..."\n\
  ollama pull qwen2.5:0.5b\n\
fi\n\
\n\
if ! ollama list | grep -q mistral; then\n\
  echo "Pulling Mistral:7b..."\n\
  ollama pull mistral:7b\n\
fi\n\
\n\
echo "Models ready!"\n\
\n\
# Keep Ollama running in foreground\n\
wait $OLLAMA_PID\n\
' > /startup.sh && chmod +x /startup.sh

# Expose Ollama port
EXPOSE 11434

# Health check
HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:11434/api/tags || exit 1

# Start Ollama with model management
CMD ["/startup.sh"]
