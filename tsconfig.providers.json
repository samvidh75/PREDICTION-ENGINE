{
  "extends": "./tsconfig.backend.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "src/services/providers/**/*.ts",
    "src/services/data/**/*.ts",
    "src/providers/v2/**/*.ts",
    "src/providers/yfinance/ProviderFailoverConfig.ts",
    "src/services/providers/broker/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
