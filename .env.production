# StockStory India Production Environment Variables

# ── Runtime ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
HOST=0.0.0.0
LOG_LEVEL=info

# ── API Base URL for frontend (points to Render backend) ──────────
VITE_API_BASE_URL=https://stockstory-api.onrender.com

# ── Database (PostgreSQL via Neon free tier) ───────────────────────
DATABASE_URL=postgresql://set-in-neon-dashboard
DB_ADAPTER=postgres
ALLOW_SQLITE_FALLBACK=false
ALLOW_SQLITE_IN_PRODUCTION=false
FORCE_MIGRATIONS=true

# ── Security ───────────────────────────────────────────────────────
COOKIE_SECRET=set-in-render-dashboard

# ── CORS ───────────────────────────────────────────────────────────
EXTRA_ALLOWED_ORIGINS=https://stockstory-india.com,https://www.stockstory-india.com

# ── Redis (Upstash Redis free tier) ───────────────────────────────
REDIS_URL=rediss://set-in-upstash-dashboard

# ── LLM / AI (backend uses either local Ollama or deterministic fallback) ─
LOCAL_AI_ENABLED=true
OLLAMA_URL=http://ollama:11434
SGLANG_URL=
ENABLE_RESEARCH_BOT=true
ENABLE_SCORE_EXPLANATIONS=true
ENABLE_STOCK_SNAPSHOTS=true
ENABLE_STOCK_COMPARISON=true
ENABLE_SCANNER_THESES=true
ENABLE_THESIS_TRACKING=true

# ── LLM / AI (optional — local LLM explainer) ─────────────────────
LOCAL_LLM_EXPLAINER_ENABLED=false
OLLAMA_EXPLAINER_URL=http://127.0.0.1:11434
OLLAMA_EXPLAINER_MODEL=mistral:7b-instruct-v0.3-q4_K_M
LLM_EXPLAINER_TIMEOUT_MS=15000

# ── Market Data ───────────────────────────────────────────────────
INDIANAPI_KEY=set-in-render-dashboard

# ── Upstox ─────────────────────────────────────────────────────────
UPSTOX_ACCESS_TOKEN=set-in-render-dashboard
UPSTOX_CLIENT_SECRET=set-in-render-dashboard
UPSTOX_CLIENT_ID=set-in-render-dashboard
UPSTOX_REDIRECT_URI=set-in-render-dashboard
UPSTOX_API_KEY=set-in-render-dashboard

# ── Public NSE Providers ────────────────────────────────────────────
JUGAD_DATA_ENABLED=true
NSEPYTHON_ENABLED=true
PUBLIC_NSE_PROVIDER_TIMEOUT_MS=30000
PUBLIC_MARKET_BROKER_ENABLED=true
PUBLIC_MARKET_BROKER_TIMEOUT_MS=30000
YAHOO_ENABLED=false

# ── Yahoo Finance ───────────────────────────────────────────────────
YFINANCE_ENABLED=true
YFINANCE_CACHE_PATH=tmp/yfinance-cache.json
YFINANCE_CACHE_SECONDS=3600
YFINANCE_BATCH_SIZE=40
YFINANCE_DOWNLOAD_TIMEOUT_SECONDS=15
YFINANCE_MIN_DELAY_SECONDS=2.0

# ── Groq LLM ────────────────────────────────────────────────────────
GROQ_API_KEY=set-in-render-dashboard
GROQ_MODEL=llama-3.1-8b-instant

# ── Firebase Auth ───────────────────────────────────────────────────
FIREBASE_PROJECT_ID=stockstory-india
FIREBASE_CLIENT_EMAIL=set-in-render-dashboard
FIREBASE_PRIVATE_KEY=set-in-render-dashboard
FIREBASE_USE_APPLICATION_DEFAULT_CREDENTIALS=false

# ── Firebase Admin SDK ───────────────────────────────────────────────
FIREBASE_PROJECT_ID=stockstory-india
FIREBASE_CLIENT_EMAIL=set-in-render-dashboard
FIREBASE_PRIVATE_KEY=set-in-render-dashboard
FIREBASE_USE_APPLICATION_DEFAULT_CREDENTIALS=false

# ── Feature Flags ────────────────────────────────────────────────────
VITE_SCREENER_ENABLED=true

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_LOCK_TIMEOUT_MS=3600000
PIPELINE_MAX_RETRIES=3
DATA_FRESHNESS_STALE_DAYS=2
DATA_FRESHNESS_CRITICAL_DAYS=7

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_MAX=20
RATE_LIMIT_REDIS_REQUIRED=true
PROVIDER_BROKER_ENABLED=true
PROVIDER_BROKER_REDIS_REQUIRED=true
MAX_PROVIDER_CALLS_PER_RUN=500

# ── Alerting ─────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=set-in-render-dashboard
DISCORD_WEBHOOK_URL=set-in-render-dashboard
ALERT_EMAIL_ENABLED=false

# ── Franchise ─────────────────────────────────────────────────────────────────
STOCKSTORY_FRANCHISE_BRAND=india

# ── Monitoring ─────────────────────────────────────────────────────────
PROMETHEUS_URL=set-in-render-dashboard
GRAFANA_URL=https://stockstory.grafana.net

# ── Public Fundamentals ───────────────────────────────────────────────
PUBLIC_FUNDAMENTALS_ENABLED=false
CSV_FUNDAMENTALS_PATH=./data/fundamentals

# ── BETA / WAITLIST / FEEDBACK ──────────────────────────────────────────────
BETA_MODE=closed
VITE_BETA_MODE=closed
VITE_WAITLIST_ENABLED=true
VITE_WAITLIST_API_URL=/api/waitlist
VITE_FEEDBACK_ENABLED=true
VITE_FEEDBACK_API_URL=/api/feedback
VITE_FEEDBACK_OG_IMAGE_URL=
VITE_CHANGELOG_ENABLED=true
VITE_USER_INTERVIEW_SIGNUP_ENABLED=true
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_WRITE_KEY=
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://app.posthog.com
VITE_PUBLIC_SENTRY_DSN=
