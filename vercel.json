{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://stockstory-api.onrender.com/api/:path*"
    },
    {
      "source": "/healthz",
      "destination": "https://stockstory-api.onrender.com/healthz"
    },
    {
      "source": "/((?!api|healthz).*)",
      "destination": "/index.html"
    }
  ]
}
