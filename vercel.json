{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "dist/public",
  "trailingSlash": false,
  "github": {
    "silent": true
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://stockstory-api.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
