{
  "version": 2,
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://stockstory-api.onrender.com/api/:path*"
    },
    {
      "source": "/healthz",
      "destination": "https://stockstory-api.onrender.com/healthz"
    },
    {
      "source": "/readyz",
      "destination": "https://stockstory-api.onrender.com/readyz"
    },
    {
      "source": "/((?!api|healthz|readyz).*)",
      "destination": "/index.html"
    }
  ]
}
