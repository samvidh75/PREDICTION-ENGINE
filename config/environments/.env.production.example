# ╔══════════════════════════════════════════════════════╗
# ║  StockStory India — Production Environment                  ║
# ║  All required env vars for Render + Neon + Upstash setup.   ║
# ║  Copy to .env.production (gitignored) and fill secrets.     ║
# ╚══════════════════════════════════════════════════════╝

# ── Node/Server ─────────────────────────────────────────────────
NODE_ENV=production
PORT=4001
HOST=0.0.0.0

# ── Database (Neon PostgreSQL) ──────────────────────────────────
DB_ADAPTER=postgres
ALLOW_SQLITE_FALLBACK=false
ALLOW_SQLITE_IN_PRODUCTION=false
DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
FORCE_MIGRATIONS=true

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=rediss://default:your_token_here@xxxx.upstash.io:6379

# ── Security ──────────────────────────────────────────────────
# Generate: openssl rand -base64 64
COOKIE_SECRET=replace_with_cookie_secret

# ── Firebase Admin SDK (token verification) ──────────────────────
FIREBASE_PROJECT_ID=stockstory-india
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@stockstory-india.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
FIREBASE_USE_APPLICATION_DEFAULT_CREDENTIALS=false

# ── Provider Credentials ────────────────────────────────────────
# Set in Render Dashboard Environment Variables. Never commit live keys.
INDIANAPI_KEY=your_indianapi_key_here

# ── Upstox Sandbox Mode ─────────────────────────────────────────
# Set UPSTOX_SANDBOX_ENABLED=true or UPSTOX_SANDBOX_MODE=true to enable sandbox mode.
# When sandbox mode is active, the code uses sandbox-api.upstox.com/v2
# and reads UPSTOX_SANDBOX_ACCESS_TOKEN instead of UPSTOX_ACCESS_TOKEN.
# Set UPSTOX_SANDBOX_ACCESS_TOKEN in Render Dashboard. Never commit it.
UPSTOX_SANDBOX_ENABLED=false
UPSTOX_SANDBOX_MODE=false
# UPSTOX_SANDBOX_ACCESS_TOKEN=paste-token-in-render-dashboard-only
# ── Yahoo Finance / yfinance research bridge ────────────────────
YFINANCE_ENABLED=true
YFINANCE_CACHE_PATH=tmp/yfinance-cache.json
YFINANCE_CACHE_SECONDS=3600
YFINANCE_REQUEST_CACHE_ENABLED=false
YFINANCE_REQUEST_CACHE_NAME=tmp/yfinance-http-cache
YFINANCE_BATCH_SIZE=40
YFINANCE_DOWNLOAD_TIMEOUT_SECONDS=15
YFINANCE_MIN_DELAY_SECONDS=2.0
YFINANCE_MAX_DELAY_SECONDS=4.0

# ── Public NSE Provider Config (no credentials needed) ─────────
JUGAD_DATA_ENABLED=true
# NSELIB_ENABLED is removed — nselib evaluated and not active. See docs/data/nselib-provider.md
NSEPYTHON_ENABLED=true
PUBLIC_NSE_PROVIDER_TIMEOUT_MS=30000
PUBLIC_PROVIDER_HEALTH_TIMEOUT_MS=6000

# ── Public Market Provider Broker ─────────────────────────────
PUBLIC_MARKET_BROKER_ENABLED=true
PUBLIC_MARKET_BROKER_TIMEOUT_MS=30000

# ── Yahoo Finance (blocked from India — 429 rate-limited) ─────
YAHOO_ENABLED=false

# ── Public Fundamentals (not yet automatic) ────────────────────
PUBLIC_FUNDAMENTALS_ENABLED=false
CSV_FUNDAMENTALS_PATH=./data/fundamentals

# ── Alerting Channels (optional) ────────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
ALERT_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@stockstory.in
ALERT_EMAIL_TO=admin@stockstory.in

# ── Pipeline ─────────────────────────────────────────────────
PIPELINE_LOCK_TIMEOUT_MS=3600000
PIPELINE_MAX_RETRIES=3
DATA_FRESHNESS_STALE_DAYS=2
DATA_FRESHNESS_CRITICAL_DAYS=7

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_MAX=20
RATE_LIMIT_REDIS_REQUIRED=true
RATE_LIMIT_SINGLE_INSTANCE_ALLOWED=false

# ── Provider Broker ──────────────────────────────────────────
PROVIDER_BROKER_ENABLED=true
PROVIDER_BROKER_REDIS_REQUIRED=true
PROVIDER_BROKER_SINGLE_INSTANCE_ALLOWED=false
MAX_PROVIDER_CALLS_PER_RUN=500

# ── Feature Flags ────────────────────────────────────────────
ENABLE_PREDICTION_FACTORY=true
ENABLE_OUTCOME_VALIDATOR=true
ENABLE_DAILY_FEED=true
ENABLE_TRUST_CENTRE=true
ENABLE_ALERTING=true
ENABLE_RATE_LIMITING=true

# ── F5: Unified Prediction Engine ──────────────────────────
UNIFIED_PREDICTION_ENGINE_ENABLED=false
UNIFIED_PREDICTION_ENGINE_SHADOW_MODE=false
F5_SCORE_SNAPSHOT_DELEGATE=false
F5_PREDICTION_FACTORY_DELEGATE=false
CONFIRM_UNIFIED_ENGINE_APPLY=false
UNIFIED_ENGINE_MODEL_VERSION=unified-v1.0.0

# ── Franchise Labels/Flags ─────────────────────────────────────
STOCKSTORY_FRANCHISE_BRAND=india
