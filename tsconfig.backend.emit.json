{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "outDir": "dist/backend",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "sourceMap": true,
    "noEmit": false,
    "types": ["node"]
  },
  "include": [
    "src/backend/**/*",
    "src/db/**/*",
    "src/intelligence/SignalValidationEngine.ts",
    "src/intelligence/PredictionDiffEngine.ts",
    "src/intelligence/AttentionEngine.ts",
    "src/intelligence/PredictionExplanationEngine.ts",
    "src/intelligence/SignalFeedEngine.ts",
    "src/intelligence/DataFreshnessEngine.ts",
    "src/services/FeatureEngine.ts",
    "src/services/FactorEngine.ts",
    "src/services/ExplanationEngine.ts",
    "src/middleware/RateLimiter.ts",
    "src/symbols/SymbolCanonicalizer.ts",
    "src/shared/symbols/SymbolNormalizer.ts",
    "src/predictions/PredictionFactory.ts",
    "src/predictions/PredictionSafetyGuard.ts",
    "src/validation/OutcomeValidator.ts",
    "src/validation/PredictionAccuracyEngine.ts",
    "src/validation/ModelHealthEngine.ts",
    "src/validation/SectorDriftEngine.ts",
    "src/portfolio/PortfolioOutcomeEngine.ts",
    "src/discovery/SectorRegistry.ts",
    "src/monitoring/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/components",
    "src/pages",
    "src/app",
    "src/shared/ui",
    "src/integrations/tradingview",
    "src/providers/coverage",
    "src/providers/screener",
    "src/providers/upstox",
    "src/providers/yahoo",
    "src/quality",
    "src/startup",
    "src/views",
    "src/scripts",
    "src/services/retention",
    "src/services/company",
    "src/services/portfolio"
  ]
}
