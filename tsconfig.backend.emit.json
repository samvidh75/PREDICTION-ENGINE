{
  "extends": "./tsconfig.backend.json",
  "compilerOptions": {
    "noEmit": false,
    "allowJs": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts"
  ]
}
