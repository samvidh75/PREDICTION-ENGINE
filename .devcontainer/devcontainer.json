{
  "name": "PREDICTION-ENGINE Dev",
  "dockerComposeFile": ["../docker-compose.dev.yml"],
  "service": "app",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "forwardPorts": [4001, 5173],
  "postCreateCommand": "npm ci && npm run bootstrap:dev",
  "remoteUser": "node"
}
