{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "types": ["vite/client", "vitest/globals"]
  },
  "include": [
    "src/env-shim.js",
    "src/main.tsx",
    "src/App.tsx",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/pages/**/*.ts",
    "src/pages/**/*.tsx",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/components/**/*.jsx",
    "src/views/**/*.ts",
    "src/views/**/*.tsx",
    "src/views/**/*.jsx",
    "src/hooks/**/*.ts",
    "src/hooks/**/*.tsx",
    "src/lib/**/*.ts",
    "src/lib/**/*.tsx",
    "src/config/**/*.ts",
    "src/config/**/*.tsx",
    "src/context/**/*.ts",
    "src/context/**/*.tsx",
    "src/context/**/*.jsx",
    "src/shared/**/*.ts",
    "src/shared/**/*.tsx",
    "src/styles/**/*.ts",
    "src/styles/**/*.tsx",
    "src/services/auth/sessionStore.ts",
    "src/services/auth/userProfile.ts",
    "src/services/auth/userProfileStore.ts",
    "src/services/auth/AuthStateLogger.ts",
    "src/services/intelligence/marketState.ts",
    "src/design-system/**/*.ts",
    "src/design-system/**/*.tsx",
    "src/designSystem/**/*.ts",
    "src/designSystem/**/*.tsx",
    "src/analytics/**/*.ts",
    "src/analytics/**/*.tsx",
    "src/store/**/*.ts",
    "src/store/**/*.tsx",
    "src/utils/**/*.ts",
    "src/utils/**/*.tsx",
    "src/types/**/*.ts",
    "src/types/**/*.tsx",
    "src/systems/**/*.ts",
    "src/systems/**/*.tsx",
    "src/engines/**/*.ts",
    "src/providers/*.ts",
    "src/services/*.ts",
    "src/data-plane/**/*.ts",
    "src/aggregators/**/*.ts",
    "src/utils/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "archive",
    "reports",
    "tmp-verification",
    "src/backend/**",
    "src/db/**",
    "src/scripts/**",
    "src/backtest/**",
    "src/calibration/**",
    "src/data/**",
    "src/monitoring/**",
    "src/opportunities/**",
    "src/ops/**",
    "src/portfolio/**",
    "src/predictions/**",
    "src/providers/v2/**",
    "src/providers/marketData/**",
    "src/providers/publicMarketData/**",
    "src/providers/upstox/**",
    "src/providers/yfinance/**",
    "src/providers/coverage/**",
    "src/providers/instruments/**",
    "src/api/**",
    "src/workers/**",
    "src/queue/**",
    "src/db/migrations/**",
    "src/db/queries/**",
    "src/quality/**",
    "src/statements/**",
    "src/validation/**",
    "src/watchlists/**",
    "src/scheduler/**",
    "src/middleware/**",
    "src/performance/**",
    "src/risk/**",
    "src/stockstory/**",
    "src/symbols/**",
    "src/engine/**",
    "src/explainability/**",
    "src/core/**",
    "src/compliance/**",
    "src/architecture/**",
    "src/discovery/**",
    "src/intelligence/**",
    "src/services/acquisition/**",
    "src/services/api/**",
    "src/services/assistant/**",
    "src/services/audit/**",
    "src/services/behavior/**",
    "src/services/brokers/**",
    "src/services/charting/**",
    "src/services/community/**",
    "src/services/company/**",
    "src/services/copilot/**",
    "src/services/data/**",
    "src/services/db/**",
    "src/services/diagnostics/**",
    "src/services/discovery/**",
    "src/services/dna/**",
    "src/services/earnings/**",
    "src/services/focusGuidance/**",
    "src/services/healthometer/**",
    "src/services/market/**",
    "src/services/marketData/**",
    "src/services/news/**",
    "src/services/notifications/**",
    "src/services/onboarding/**",
    "src/services/personalization/**",
    "src/services/portfolio/**",
    "src/services/premium/**",
    "src/services/providers/**",
    "src/services/realtime/**",
    "src/services/retention/**",
    "src/services/stocks/**",
    "src/services/subscriptions/**",
    "src/services/synthesis/**",
    "src/services/telemetry/**",
    "src/services/ui/**",
    "src/services/universe/**",
    "src/services/!(auth|intelligence)/*.ts",
    "src/__tests__/**",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/components/HealthometerWidget.jsx",
    "src/components/MarketHydrator.jsx",
    "src/views/PracticeTerminal.jsx",
    "src/components/intelligence/ResponsiveUIScalingLayer.tsx"
  ]
}
