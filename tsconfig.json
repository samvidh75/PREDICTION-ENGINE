{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": false,
    "types": [
      "vite/client",
      "vitest/globals"
    ],
    "paths": {}
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "src/components/HealthometerWidget.jsx",
    "src/components/MarketHydrator.jsx",
    "src/views/PracticeTerminal.jsx",
    "src/scripts/calibrate.ts",
    "src/scripts/calibrate_v2.ts",
    "src/scripts/run-explainability-pipeline.ts",
    "src/intelligence"
  ]
}
